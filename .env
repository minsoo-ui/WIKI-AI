# ============================================
# WIKI-AI Environment Configuration
# ============================================

# --- App ---
APP_NAME=WIKI-AI
APP_VERSION=0.1.0
DEBUG=True

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
SQLITE_URL=sqlite+aiosqlite:///./data/wiki_ai.db

# --- Qdrant Vector DB ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=wiki_documents
QDRANT_USE_LOCAL=False
QDRANT_LOCAL_PATH=./data/qdrant_storage

# --- Embedding ---
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_BACKEND=ollama
EMBEDDING_OLLAMA_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# --- LLM ---
LLM_MODEL=qwen3:0.6b
LLM_BACKEND=ollama
OLLAMA_HOST=http://localhost:11434

# --- Redis (Optional) ---
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=False

# --- LangFuse (Optional) ---
LANGFUSE_ENABLED=False
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- Auth ---
SECRET_KEY=your-super-secret-key-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
